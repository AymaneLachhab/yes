def main():
    if not os.path.exists(OUTPUT_BASE_DIR):
        os.makedirs(OUTPUT_BASE_DIR)

    print("\n==========================================")
    print("      MALWARE STREAM ANALYZER (SAFE)      ")
    print("==========================================")
    
    print("\nCatégories disponibles :")
    for i, cls in enumerate(CLASSES):
        print(f"[{i+1}] {cls}")
        
    try:
        choix = input(f"\n>>> Choisissez le numéro de la catégorie (1-{len(CLASSES)}) : ")
        idx = int(choix) - 1
        if idx < 0 or idx >= len(CLASSES):
            print("[-] Choix invalide.")
            return
    except ValueError:
        print("[-] Veuillez entrer un numéro valide.")
        return
        
    malware_class = CLASSES[idx]
    print(f"\n[+] Vous avez sélectionné la catégorie : {malware_class.upper()}")
    
    # Dossier temporaire
    class_dir = os.path.join(OUTPUT_BASE_DIR, malware_class)
    if not os.path.exists(class_dir):
        os.makedirs(class_dir)
        
    # Dossier final pour l'ASM
    asm_dir = f"asm_{malware_class}"
    if not os.path.exists(asm_dir):
        os.makedirs(asm_dir)
        
    print(f"\n==================================================")
    print(f"[*] TRAITEMENT EN CONTINU (Objectif: {SAMPLES_PER_FAMILY})")
    print(f"==================================================")
    hashes = get_hashes(malware_class, SAMPLES_PER_FAMILY)
    
    if not hashes:
        print("[-] Aucun sample trouvé. Fin du script.")
        return
        
    success_count = 0
    for i, sha256 in enumerate(hashes):
        if success_count >= SAMPLES_PER_FAMILY:
            print(f"\n[+] Objectif atteint: {SAMPLES_PER_FAMILY} malwares analysés.")
            break
            
        print(f"\n    [Progression : {success_count}/{SAMPLES_PER_FAMILY}] -> Sample {sha256}")
        
        # Vérifier si on a déjà traité ce malware
        asm_path = os.path.join(asm_dir, f"{sha256}.asm")
        if os.path.exists(asm_path):
            print("        [~] L'analyse a déjà été faite (uploadée sur GitHub), on passe.")
            success_count += 1
            continue
            
        # 1. Télécharger et extraire
        print("        [*] Téléchargement et extraction...")
        extracted_file = download_and_extract(sha256, class_dir)
        
        if extracted_file and os.path.exists(extracted_file):
            # 2. Objdump
            print("        [*] Désassemblage (objdump)...")
            try:
                cmd = f"objdump -d '{extracted_file}' > '{asm_path}' 2>/dev/null"
                subprocess.run(cmd, shell=True)
                
                if os.path.exists(asm_path) and os.path.getsize(asm_path) == 0:
                    os.remove(asm_path)
                    print("        [-] Format non reconnu par objdump (ignoré).")
                else:
                    print("        [+] Désassemblage réussi -> Fichier ASM sauvegardé.")
                    
                    # 2.5 Upload sur Github
                    if GITHUB_TOKEN:
                        upload_to_github(asm_path, malware_class, f"{sha256}.asm")
                        # Vider le fichier localement pour libérer 100% de l'espace disque,
                        # tout en gardant le fichier vide comme "marqueur" de réussite.
                        open(asm_path, 'w').close()
                        
                    success_count += 1
            except Exception as e:
                print(f"        [!] Erreur objdump: {e}")
                
            # 3. Suppression IMÉDIATE
            print("        [*] Suppression du malware...")
            try:
                os.remove(extracted_file)
                print("        [+] Malware supprimé avec succès.")
            except Exception as e:
                print(f"        [!] Erreur lors de la suppression: {e}")
        
        time.sleep(1) # Pause API pour ne pas se faire bloquer
        
    print(f"\n==================================================")
    print(f"[*] BILAN : {success_count} fichiers traités pour la classe {malware_class}.")
    print(f"[*] Les fichiers de code source (ASM) sont 100% inoffensifs et stockés ici :")
    print(f"    -> {os.path.abspath(asm_dir)}")
    print(f"==================================================")

if __name__ == "__main__":
    main()
