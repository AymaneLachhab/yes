def get_hashes(malware_class, limit):
    """Récupère une liste de hash SHA256 (Uniquement PE Windows) pour une CLASSE générale donnée"""
    print(f"[*] Recherche de samples pour la classe: {malware_class} (Filtre PE Windows activé)...")
    data = {
        'query': 'get_taginfo',
        'tag': malware_class,
        'limit': min(limit, 1000)  # Utilise la limite passée en paramètre (maximum 1000 pour l'API)
    }
    
    try:
        response = requests.post(API_URL, data=data, headers=HEADERS, timeout=60)
        
        try:
            response_json = response.json()
        except ValueError:
            # Si l'API renvoie du HTML (erreur Cloudflare, Rate Limit, etc.) au lieu du JSON
            print(f"    [!] L'API n'a pas renvoyé de JSON. Code d'erreur HTTP: {response.status_code}")
            return []
            
        if response_json.get('query_status') == 'ok':
            hashes = []
            for item in response_json.get('data', []):
                # Filtrer pour TOUS les fichiers PE Windows
                ftype = item.get('file_type', '').lower()
                
                if ftype in ('exe', 'dll', 'sys', 'ocx', 'scr', 'cpl', 'drv', 'msi'):
                    hashes.append(item['sha256_hash'])
                    
            print(f"    [+] Trouvé {len(hashes)} samples PE Windows (EXE+DLL).")
            if len(hashes) < SAMPLES_PER_FAMILY:
                print(f"    [!] Attention : seulement {len(hashes)} disponibles (objectif: {SAMPLES_PER_FAMILY})")
            return hashes
        else:
            print(f"    [-] Erreur API ou aucun sample trouvé: {response_json.get('query_status')}")
            return []
    except Exception as e:
        print(f"    [!] Erreur de connexion: {e}")
        return []

def upload_to_github(local_file_path, malware_class, filename):
    """Upload un fichier directement sur Github via leur API REST"""
    if not GITHUB_TOKEN:
        return False
        
    print(f"        [*] Upload vers GitHub ({GITHUB_REPO})...")
    # Met la première lettre en majuscule (ex: ransomware -> Ransomware)
    class_folder = malware_class.capitalize() 
    github_path = f"{GITHUB_BASE_PATH}/{class_folder}/{filename}"
    
    url = f"https://api.github.com/repos/{GITHUB_REPO}/contents/{github_path}"
    headers = {
        "Authorization": f"Bearer {GITHUB_TOKEN.strip()}",
        "Accept": "application/vnd.github.v3+json"
    }
    
    try:
        # Vérification de la taille (GitHub API limite l'upload de fichiers uniques)
        # Certains malwares désassemblés génèrent des ASM gigantesques.
        file_size_mb = os.path.getsize(local_file_path) / (1024 * 1024)
        if file_size_mb > 45: # Limite arbitraire de sécurité à 45 Mo
            print(f"        [-] Fichier ASM trop lourd pour GitHub API ({file_size_mb:.1f} MB). Ignoré.")
            return False

        with open(local_file_path, "rb") as f:
            content = f.read()
        
        # Github demande du Base64 pour le contenu des fichiers
        encoded_content = base64.b64encode(content).decode("utf-8")
        
        data = {
            "message": f"Ajout ASM automatique: {filename} ({class_folder})",
            "content": encoded_content,
            "branch": "main"
        }
        
        response = requests.put(url, json=data, headers=headers, timeout=60)
        
        if response.status_code in [201, 200]:
            print(f"        [+] Upload GitHub réussi ! ({github_path})")
            return True
        else:
            print(f"        [-] Erreur GitHub API ({response.status_code})")
            try:
                print(f"            {response.json().get('message')}")
            except:
                pass
            return False
    except Exception as e:
        print(f"        [!] Erreur lors de l'upload GitHub: {e}")
        return False

def download_and_extract(sha256, output_dir):
    """Télécharge le fichier ZIP depuis MalwareBazaar, l'extrait, et retourne le chemin complet du fichier extrait"""
    data = {
        'query': 'get_file',
        'sha256_hash': sha256
    }
    
    try:
        response = requests.post(API_URL, data=data, headers=HEADERS, timeout=30)
        
        if response.content.startswith(b'PK'):
            zip_path = os.path.join(output_dir, f"{sha256}.zip")
            
            with open(zip_path, 'wb') as f:
                f.write(response.content)
            
            try:
                extracted_file_path = None
                with pyzipper.AESZipFile(zip_path) as zf:
                    # Récupérer le nom interne du fichier
                    file_names = zf.namelist()
                    if file_names:
                        extracted_file_path = os.path.join(output_dir, file_names[0])
                    # Extraire
                    zf.extractall(path=output_dir, pwd=b'infected')
                
                # Suppression du ZIP
                os.remove(zip_path)
                return extracted_file_path
            except Exception as e:
                print(f"        [!] Erreur d'extraction: {e}")
                if os.path.exists(zip_path):
                    os.remove(zip_path)
                return None
        else:
            try:
                error_msg = response.json().get('query_status', 'Erreur inconnue')
                print(f"        [-] Erreur API (Quota atteint ou Fichier introuvable): {error_msg}")
            except:
                pass
            return None
            
    except Exception as e:
        print(f"        [!] Erreur de téléchargement: {e}")
        return None

# ==========================================
# PROCESSING MULTI-THREAD
# ==========================================
def process_sample(sha256, malware_class, class_dir, asm_dir):
    """Traite un seul sample (téléchargement, objdump, upload, nettoyage)"""
    asm_path = os.path.join(asm_dir, f"{sha256}.asm")
    if os.path.exists(asm_path):
        return True, "Déjà analysé (uploadé)"
        
    extracted_file = download_and_extract(sha256, class_dir)
    
    if extracted_file and os.path.exists(extracted_file):
        try:
            cmd = f"objdump -d '{extracted_file}' > '{asm_path}' 2>/dev/null"
            subprocess.run(cmd, shell=True)
            
            if os.path.exists(asm_path) and os.path.getsize(asm_path) == 0:
                os.remove(asm_path)
                status = (False, "Format non reconnu par objdump")
            else:
                if GITHUB_TOKEN:
                    upload_success = upload_to_github(asm_path, malware_class, f"{sha256}.asm")
                    if os.path.exists(asm_path):
                        os.remove(asm_path)
                    status = (upload_success, "Upload GitHub réussi" if upload_success else "Échec upload (trop gros?)")
                else:
                    status = (True, "Désassemblé avec succès (sauvegarde locale)")
        except Exception as e:
            status = (False, f"Erreur objdump: {e}")
            
        # Nettoyage de l'exécutable
        try:
            if os.path.exists(extracted_file):
                os.remove(extracted_file)
        except:
            pass
            
        time.sleep(1) # Pause API pour ne pas se faire bloquer par le serveur
        return status
        
    return False, "Échec téléchargement ou extraction"

def process_category(malware_class):
    print(f"\n[*] Démarrage du thread pour la catégorie : {malware_class.upper()}")
    
    # Dossier temporaire
    class_dir = os.path.join(OUTPUT_BASE_DIR, malware_class)
    if not os.path.exists(class_dir):
        os.makedirs(class_dir, exist_ok=True)
        
    # Dossier final pour l'ASM
    asm_dir = f"asm_{malware_class}"
    if not os.path.exists(asm_dir):
        os.makedirs(asm_dir, exist_ok=True)
        
    hashes = get_hashes(malware_class, 1000)
    
    if not hashes:
        print(f"[-] Aucun sample trouvé pour {malware_class}.")
        return
        
    success_count = 0
    for sha256 in hashes:
        if success_count >= SAMPLES_PER_FAMILY:
            print(f"\n[+] Objectif atteint pour {malware_class}: {SAMPLES_PER_FAMILY} malwares analysés.")
            break
            
        success, message = process_sample(sha256, malware_class, class_dir, asm_dir)
        
        if success:
            success_count += 1
            print(f"    [+] {malware_class} | {sha256} -> {message} (Total: {success_count}/{SAMPLES_PER_FAMILY})")
        else:
            print(f"    [-] {malware_class} | {sha256} -> {message}")
            
    print(f"\n==================================================")
    print(f"[*] BILAN {malware_class.upper()} : {success_count} fichiers traités.")
    print(f"[*] Stockés ici : {os.path.abspath(asm_dir)}")
    print(f"==================================================")


