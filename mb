def main():
    if not os.path.exists(OUTPUT_BASE_DIR):
        os.makedirs(OUTPUT_BASE_DIR, exist_ok=True)

    print("\n==========================================")
    print("      MALWARE STREAM ANALYZER (SAFE)      ")
    print("==========================================")
    
    print("\nCatégories disponibles :")
    print("[0] TOUTES les catégories")
    for i, cls in enumerate(CLASSES):
        print(f"[{i+1}] {cls}")
        
    try:
        choix = input(f"\n>>> Choisissez les numéros séparés par des virgules (ex: 1,3) ou 0 pour TOUT : ")
        
        selected_classes = []
        if choix.strip() == '0':
            selected_classes = CLASSES
        else:
            indices = [int(x.strip()) - 1 for x in choix.split(',')]
            for idx in indices:
                if 0 <= idx < len(CLASSES):
                    selected_classes.append(CLASSES[idx])
                else:
                    print(f"[-] Choix invalide ignoré: {idx + 1}")
                    
        if not selected_classes:
            print("[-] Aucune catégorie valide sélectionnée.")
            return
            
    except ValueError:
        print("[-] Veuillez entrer des numéros valides.")
        return
        
    print(f"\n[+] Catégories sélectionnées : {', '.join(selected_classes).upper()}")
    print(f"\n[*] Lancement de workers en parallèle pour chaque catégorie...\n")
    
    # On lance 1 thread par catégorie (max 10 pour ne pas saturer la machine)
    max_cat_workers = min(len(selected_classes), 10)
    with concurrent.futures.ThreadPoolExecutor(max_workers=max_cat_workers) as executor:
        futures = [executor.submit(process_category, cls) for cls in selected_classes]
        concurrent.futures.wait(futures)
        
    print("\n[+] TOUTES LES CATÉGORIES SONT TERMINÉES.")

if __name__ == "__main__":
    main()
